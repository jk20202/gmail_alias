{
  "name": "mail-alias-cloudflare",
  "version": "1.0.0",
  "description": "部署在 Cloudflare Workers 上的别名邮箱管理系统 (Gmail + Outlook/Hotmail OAuth + Webhook)",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute mail_alias --file=./schema.sql",
    "db:remote:init": "wrangler d1 execute mail_alias --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240329.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.48.0"
  }
}
